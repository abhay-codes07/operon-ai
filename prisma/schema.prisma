  tool           Tool         @relation("ToolVersions", fields: [toolId], references: [id], onDelete: Cascade)
  executions     ToolExecution[]
  installations  ToolInstallation[]

  @@unique([toolId, versionNumber])
  @@index([organizationId, validated, createdAt])
}

