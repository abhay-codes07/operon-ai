  id            String            @id @default(cuid())
  pipelineId    String
  orgId         String
  status        PipelineRunStatus @default(RUNNING)
  startedAt     DateTime          @default(now())
  completedAt   DateTime?
  inputPayload  Json?
  contextPayload Json?
  errorMessage  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  pipeline      Pipeline          @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  organization  Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  stepRuns      PipelineStepRun[]

  @@index([orgId, status, startedAt])
  @@index([pipelineId, startedAt])
}

model PipelineStepRun {
  id            String                @id @default(cuid())
  pipelineRunId String
  stepId        String
  orgId         String
  agentRunId    String?
  status        PipelineStepRunStatus @default(QUEUED)
  startedAt     DateTime?
  completedAt   DateTime?
  inputPayload  Json?
  outputPayload Json?
  errorMessage  String?
  retryCount    Int                   @default(0)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  pipelineRun   PipelineRun           @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
  step          PipelineStep          @relation(fields: [stepId], references: [id], onDelete: Cascade)
  organization  Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  agentRun      Execution?            @relation("PipelineStepRunExecution", fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([pipelineRunId, status, createdAt])
  @@index([orgId, status, createdAt])
  @@index([agentRunId])
}
