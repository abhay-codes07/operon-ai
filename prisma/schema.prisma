generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum AgentStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ExecutionStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ExecutionTrigger {
  MANUAL
  SCHEDULED
  API
  RETRY
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum ExecutionStepStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum MemoryKind {
  RUN_METADATA
  PATTERN
  FAILURE_RESOLUTION
}

enum SimulationStatus {
  READY
  FAILED
}

enum FailureCategory {
  SELECTOR_DRIFT
  NAVIGATION_FAILURE
  AUTHENTICATION_ISSUE
  PAGE_LOAD_TIMEOUT
  UNKNOWN
}

enum ChangeType {
  ADDED
  REMOVED
  MODIFIED
}

enum ChangeSeverity {
  LOW
  MEDIUM
  HIGH
}

enum ExecutionControlAction {
  PAUSE
  RESUME
  STEP
  OVERRIDE_ACTION
  STOP
}

enum ExecutionControlCommandStatus {
  PENDING
  APPLIED
  REJECTED
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ToolExecutionStatus {
  SUCCEEDED
  FAILED
}

enum FleetStatus {
  RUNNING
  IDLE
  FAILED
  RETRYING
}

enum HealthStatus {
  HEALTHY
  DEGRADED
  CRITICAL
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum RunbookExecutionStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
}

enum PolicyRuleType {
  DOMAIN_ALLOWLIST
  ACTION_ALLOWLIST
}

enum PolicyDecision {
  ALLOW
  DENY
}

enum AuditResult {
  APPROVED
  BLOCKED
  FAILED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkflowReleaseStatus {
  ACTIVE
  PAUSED
  ROLLED_BACK
  COMPLETED
}

enum ReleaseLane {
  STABLE
  CANARY
}

enum MarketplacePricingModel {
  FREE
  PAID
}

enum TemplateInstallationStatus {
  ACTIVE
  PAUSED
}

enum BusinessImpactCategory {
  REVENUE_PROTECTION
  COST_SAVINGS
  COMPLIANCE
  GROWTH
}

enum SLABreachType {
  FAILURE_RATE
  EXECUTION_TIMEOUT
  MISSED_SCHEDULE
}

enum ComplianceActionType {
  READ
  WRITE
  SUBMIT
  EXTRACT
}

enum ComplianceRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum PipelineRunStatus {
  RUNNING
  PAUSED
  FAILED
  COMPLETED
}

enum PipelineStepRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum BillingPlan {
  FREE
  STARTER
  GROWTH
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String            @unique
  emailVerified DateTime?
  passwordHash  String
  image         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  createdAgents Agent[]           @relation("AgentCreatedBy")
  createdWorkflows Workflow[]     @relation("WorkflowCreatedBy")
  requestedExecutions Execution[] @relation("ExecutionRequestedBy")
  reviewedApprovals ApprovalRequest[] @relation("ApprovalReviewedBy")
  debugSessions DebugSession[]
  installedTools ToolInstallation[]
  complianceApprovals WorkflowComplianceApproval[] @relation("ComplianceApprovedBy")

  @@index([createdAt])
}

model Organization {
  id            String       @id @default(cuid())
  name          String
  slug          String       @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  memberships   Membership[]
  agents        Agent[]
  workflows     Workflow[]
  executions    Execution[]
  executionLogs ExecutionLog[]
  executionSteps ExecutionStep[]
  domSnapshots  DomSnapshot[]
  selfHealingRecords SelfHealingRecord[]
  agentMemories AgentMemory[]
  securityPolicy OrganizationSecurityPolicy?
  workflowSimulations WorkflowSimulation[]
  agentReliability AgentReliability[]
  executionMetrics ExecutionMetric[]
  failureAnalyses FailureAnalysis[]
  domainKnowledge DomainKnowledge[]
  agentInsights AgentInsight[]
  sharedSignals SharedSignal[]
  pageSnapshots PageSnapshot[]
  changeEvents ChangeEvent[]
  selectorHistory SelectorHistory[]
  adaptiveWorkflows AdaptiveWorkflow[]
  executionStreamEvents ExecutionStreamEvent[]
  executionControlCommands ExecutionControlCommand[]
  approvalRequests ApprovalRequest[]
  systemFlags SystemFlag[]
  debugSessions DebugSession[]
  tools Tool[]
  toolVersions ToolVersion[]
  toolExecutions ToolExecution[]
  toolInstallations ToolInstallation[]
  agentStatuses AgentStatusSnapshot[]
  agentHealthRecords AgentHealth[]
  incidents Incident[]
  incidentEvents IncidentEvent[]
  runbooks Runbook[]
  runbookExecutions RunbookExecution[]
  agentDeployments AgentDeployment[]
  agentPolicies AgentPolicy[]
  policyRules PolicyRule[]
  executionAudits ExecutionAudit[]
  auditEvents AuditEvent[]
  workflowReleases WorkflowRelease[]
  releaseRoutingLogs ReleaseRoutingLog[]
  releaseMetricSnapshots ReleaseMetricSnapshot[]
  authoredTemplates MarketplaceTemplate[] @relation("MarketplaceTemplateAuthor")
  templateInstallations TemplateInstallation[]
  templateReviews TemplateReview[]
  slaBreachIncidents SLABreachIncident[]
  complianceEvents ComplianceEvent[]
  complianceViolations ComplianceViolation[]
  workflowComplianceApprovals WorkflowComplianceApproval[]
  pipelines Pipeline[]
  pipelineRuns PipelineRun[]
  pipelineStepRuns PipelineStepRun[]
  subscriptions Subscription[]
  usageRecords  UsageRecord[]

  @@index([createdAt])
}

model Membership {
  id             String          @id @default(cuid())
  role           MembershipRole  @default(MEMBER)
  userId         String
  organizationId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role])
  @@index([userId])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agent {
  id             String      @id @default(cuid())
  organizationId String
  createdById    String
  name           String
  description    String?
  status         AgentStatus @default(DRAFT)
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User         @relation("AgentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  workflows      Workflow[]
  executions     Execution[]
  memories       AgentMemory[]
  reliability    AgentReliability?
  executionMetrics ExecutionMetric[]
  insights       AgentInsight[]
  generatedTools Tool[]
  statusHistory AgentStatusSnapshot[]
  healthHistory AgentHealth[]
  incidents Incident[]
  runbookExecutions RunbookExecution[]
  deployments AgentDeployment[]
  agentPolicy AgentPolicy?
  executionAudits ExecutionAudit[]
  pipelineSteps PipelineStep[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@unique([organizationId, name])
}

model Workflow {
  id             String         @id @default(cuid())
  organizationId String
  agentId        String
  createdById    String
  name           String
  description    String?
  status         WorkflowStatus @default(DRAFT)
  scheduleCron   String?
  definition     Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent          Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  createdBy      User           @relation("WorkflowCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  executions     Execution[]
  memories       AgentMemory[]
  simulations    WorkflowSimulation[]
  pageSnapshots  PageSnapshot[]
  changeEvents   ChangeEvent[]
  selectorHistory SelectorHistory[]
  adaptiveWorkflow AdaptiveWorkflow?
  approvalRequests ApprovalRequest[]
  installedTools ToolInstallation[]
  stableReleases WorkflowRelease[] @relation("StableWorkflow")
  canaryReleases WorkflowRelease[] @relation("CanaryWorkflow")
  releaseRoutings ReleaseRoutingLog[]
  workflowSLA WorkflowSLA?
  workflowBusinessImpact WorkflowBusinessImpact?
  slaBreachIncidents SLABreachIncident[]
  complianceApprovals WorkflowComplianceApproval[]
  complianceEvents ComplianceEvent[]
  compliancePassport CompliancePassport?
  complianceViolations ComplianceViolation[]

  @@index([organizationId, status])
  @@index([organizationId, agentId, createdAt])
  @@unique([organizationId, agentId, name])
}

model Execution {
  id             String           @id @default(cuid())
  organizationId String
  agentId        String
  workflowId     String?
  requestedById  String?
  status         ExecutionStatus  @default(QUEUED)
  trigger        ExecutionTrigger @default(MANUAL)
  inputPayload   Json?
  outputPayload  Json?
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent          Agent            @relation(fields: [agentId], references: [id], onDelete: Cascade)
  workflow       Workflow?        @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  requestedBy    User?            @relation("ExecutionRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  logs           ExecutionLog[]
  steps          ExecutionStep[]
  snapshots      DomSnapshot[]
  selfHealingRecords SelfHealingRecord[]
  memoryEntries  AgentMemory[]    @relation("MemorySourceExecution")
  metric         ExecutionMetric?
  failureAnalysis FailureAnalysis?
  pageSnapshots  PageSnapshot[]
  changeEvents   ChangeEvent[]
  streamEvents   ExecutionStreamEvent[]
  controlCommands ExecutionControlCommand[]
  approvalRequests ApprovalRequest[]
  debugSessions  DebugSession[]
  isPaused       Boolean          @default(false)
  stepCursor     Int              @default(0)
  debugMode      Boolean          @default(false)
  toolExecutions ToolExecution[]
  incidents Incident[]
  runbookExecutions RunbookExecution[]
  executionAudits ExecutionAudit[]
  releaseRouting ReleaseRoutingLog?
  slaBreachIncidents SLABreachIncident[] @relation("SLABreachRun")
  complianceEvents ComplianceEvent[] @relation("ComplianceEventRun")
  complianceViolations ComplianceViolation[] @relation("ComplianceViolationRun")
  pipelineStepRuns PipelineStepRun[] @relation("PipelineStepRunExecution")

  @@index([organizationId, status, createdAt])
  @@index([organizationId, agentId, createdAt])
  @@index([workflowId, createdAt])
}

model ExecutionLog {
  id             String     @id @default(cuid())
  executionId    String
  organizationId String
  level          LogLevel   @default(INFO)
  message        String
  metadata       Json?
  occurredAt     DateTime   @default(now())
  execution      Execution  @relation(fields: [executionId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([executionId, occurredAt])
  @@index([organizationId, occurredAt])
  @@index([organizationId, level, occurredAt])
}

model ExecutionStep {
  id             String              @id @default(cuid())
  executionId    String
  organizationId String
  stepIndex      Int
  stepKey        String
  action         String
  target         String?
  status         ExecutionStepStatus @default(PENDING)
  startedAt      DateTime?
  finishedAt     DateTime?
  metadata       Json?
  createdAt      DateTime            @default(now())
  execution      Execution           @relation(fields: [executionId], references: [id], onDelete: Cascade)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  snapshots      DomSnapshot[]
  selfHealingRecords SelfHealingRecord[]

  @@unique([executionId, stepIndex])
  @@index([organizationId, executionId, stepIndex])
}

model DomSnapshot {
  id              String        @id @default(cuid())
  executionId     String
  executionStepId String?
  organizationId  String
  pageUrl         String?
  domHtml         String        @db.Text
  metadata        Json?
  capturedAt      DateTime      @default(now())
  execution       Execution     @relation(fields: [executionId], references: [id], onDelete: Cascade)
  executionStep   ExecutionStep? @relation(fields: [executionStepId], references: [id], onDelete: SetNull)
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, executionId, capturedAt])
  @@index([executionStepId, capturedAt])
}

model SelfHealingRecord {
  id               String       @id @default(cuid())
  organizationId   String
  executionId      String
  executionStepId  String?
  originalSelector String?
  resolvedSelector String
  strategy         String
  similarityScore  Float
  success          Boolean      @default(true)
  metadata         Json?
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution        Execution    @relation(fields: [executionId], references: [id], onDelete: Cascade)
  executionStep    ExecutionStep? @relation(fields: [executionStepId], references: [id], onDelete: SetNull)

  @@index([organizationId, executionId, createdAt])
}

model AgentMemory {
  id                String       @id @default(cuid())
  organizationId    String
  agentId           String
  workflowId        String?
  sourceExecutionId String?
  kind              MemoryKind
  memoryKey         String
  memoryValue       Json
  confidence        Float?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent             Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  workflow          Workflow?    @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  sourceExecution   Execution?   @relation("MemorySourceExecution", fields: [sourceExecutionId], references: [id], onDelete: SetNull)

  @@unique([organizationId, agentId, workflowId, memoryKey])
  @@index([organizationId, agentId, kind, updatedAt])
}

model OrganizationSecurityPolicy {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  domainAllowlist      Json
  restrictedActions    Json
  allowedWindowStartHr Int?
  allowedWindowEndHr   Int?
  timezone             String       @default("UTC")
  requireHttps         Boolean      @default(true)
  metadata             Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AgentPolicy {
  id                   String       @id @default(cuid())
  organizationId       String
  agentId              String
  enabled              Boolean      @default(true)
  maxRunsPerHour       Int          @default(120)
  allowedWindowStartHr Int?
  allowedWindowEndHr   Int?
  timezone             String       @default("UTC")
  metadata             Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent                Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  rules                PolicyRule[]

  @@unique([organizationId, agentId])
  @@index([organizationId, enabled, updatedAt])
}

model PolicyRule {
  id             String         @id @default(cuid())
  organizationId String
  agentPolicyId  String
  ruleType       PolicyRuleType
  value          String
  enabled        Boolean        @default(true)
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentPolicy    AgentPolicy    @relation(fields: [agentPolicyId], references: [id], onDelete: Cascade)

  @@index([organizationId, ruleType, enabled, updatedAt])
  @@index([agentPolicyId, ruleType, enabled])
  @@unique([agentPolicyId, ruleType, value])
}

model ExecutionAudit {
  id             String         @id @default(cuid())
  organizationId String
  executionId    String?
  agentId        String
  action         String
  targetDomain   String?
  intentHash     String
  policyDecision PolicyDecision
  result         AuditResult
  riskLevel      RiskLevel
  riskScore      Int
  riskReason     String?
  metadata       Json?
  occurredAt     DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution      Execution?     @relation(fields: [executionId], references: [id], onDelete: SetNull)
  agent          Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  events         AuditEvent[]

  @@index([organizationId, occurredAt])
  @@index([organizationId, agentId, occurredAt])
  @@index([organizationId, result, occurredAt])
}

model AuditEvent {
  id               String         @id @default(cuid())
  organizationId   String
  executionAuditId String
  eventType        String
  message          String
  metadata         Json?
  occurredAt       DateTime       @default(now())
  organization     Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executionAudit   ExecutionAudit @relation(fields: [executionAuditId], references: [id], onDelete: Cascade)

  @@index([organizationId, occurredAt])
  @@index([executionAuditId, occurredAt])
}

model WorkflowRelease {
  id                    String                @id @default(cuid())
  organizationId        String
  agentId               String
  stableWorkflowId      String
  canaryWorkflowId      String
  status                WorkflowReleaseStatus @default(ACTIVE)
  canaryTrafficPercent  Int                   @default(10)
  autoRollbackEnabled   Boolean               @default(true)
  failureThresholdPct   Float                 @default(20)
  minCanarySampleSize   Int                   @default(20)
  totalRouted           Int                   @default(0)
  stableRouted          Int                   @default(0)
  canaryRouted          Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent                 Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  stableWorkflow        Workflow              @relation("StableWorkflow", fields: [stableWorkflowId], references: [id], onDelete: Cascade)
  canaryWorkflow        Workflow              @relation("CanaryWorkflow", fields: [canaryWorkflowId], references: [id], onDelete: Cascade)
  routings              ReleaseRoutingLog[]
  metricSnapshots       ReleaseMetricSnapshot[]

  @@index([organizationId, status, updatedAt])
  @@unique([organizationId, stableWorkflowId, canaryWorkflowId])
}

model ReleaseRoutingLog {
  id             String       @id @default(cuid())
  organizationId String
  workflowReleaseId String
  executionId    String       @unique
  workflowId     String
  lane           ReleaseLane
  status         ExecutionStatus @default(QUEUED)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflowRelease WorkflowRelease @relation(fields: [workflowReleaseId], references: [id], onDelete: Cascade)
  execution      Execution    @relation(fields: [executionId], references: [id], onDelete: Cascade)
  workflow       Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([organizationId, workflowReleaseId, createdAt])
  @@index([organizationId, lane, createdAt])
}

model ReleaseMetricSnapshot {
  id              String       @id @default(cuid())
  organizationId  String
  workflowReleaseId String
  canarySampleSize Int
  canaryFailurePct Float
  canarySuccessPct Float
  stableSampleSize Int
  stableFailurePct Float
  capturedAt       DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflowRelease  WorkflowRelease @relation(fields: [workflowReleaseId], references: [id], onDelete: Cascade)

  @@index([organizationId, workflowReleaseId, capturedAt])
}

model MarketplaceTemplate {
  id               String                @id @default(cuid())
  slug             String                @unique
  title            String
  description      String
  category         String
  authorOrgId      String
  pricingModel     MarketplacePricingModel @default(FREE)
  priceUsd         Float                 @default(0)
  reliabilityScore Float                 @default(0)
  avgRating        Float                 @default(0)
  reviewCount      Int                   @default(0)
  installCount     Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  authorOrg        Organization          @relation("MarketplaceTemplateAuthor", fields: [authorOrgId], references: [id], onDelete: Cascade)
  versions         TemplateVersion[]
  installations    TemplateInstallation[]
  reviews          TemplateReview[]

  @@index([category, reliabilityScore, installCount])
  @@index([authorOrgId, createdAt])
}

model TemplateVersion {
  id                 String              @id @default(cuid())
  templateId         String
  version            String
  workflowDefinition Json
  changelog          String?
  isLatest           Boolean             @default(false)
  publishedAt        DateTime            @default(now())
  template           MarketplaceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId, isLatest, publishedAt])
}

model TemplateInstallation {
  id               String                     @id @default(cuid())
  templateId       String
  orgId            String
  installedVersion String
  installedAt      DateTime                   @default(now())
  status           TemplateInstallationStatus @default(ACTIVE)
  template         MarketplaceTemplate        @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organization     Organization               @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([templateId, orgId])
  @@index([orgId, status, installedAt])
}

model TemplateReview {
  id         String              @id @default(cuid())
  templateId String
  orgId      String
  rating     Int
  comment    String?
  createdAt  DateTime            @default(now())
  template   MarketplaceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([templateId, orgId])
  @@index([templateId, createdAt])
}

model WorkflowSLA {
  id                       String   @id @default(cuid())
  workflowId               String   @unique
  expectedSchedule         String
  maxFailureRate           Float
  maxExecutionTimeSeconds  Int
  rollingWindowDays        Int      @default(7)
  notificationSlackChannel String?
  notificationEmail        String?
  escalationAfterBreaches  Int      @default(3)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  workflow                 Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model WorkflowBusinessImpact {
  id                          String                 @id @default(cuid())
  workflowId                  String                 @unique
  category                    BusinessImpactCategory
  estimatedDollarValuePerRun  Float
  teamOwner                   String
  businessObjective           String
  createdAt                   DateTime               @default(now())
  workflow                    Workflow               @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model SLABreachIncident {
  id            String       @id @default(cuid())
  workflowId    String
  runId         String?
  breachType    SLABreachType
  breachDetails Json
  detectedAt    DateTime     @default(now())
  resolvedAt    DateTime?
  workflow      Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  run           Execution?   @relation("SLABreachRun", fields: [runId], references: [id], onDelete: SetNull)
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  @@index([organizationId, detectedAt])
  @@index([workflowId, breachType, detectedAt])
  @@index([runId])
}

model WorkflowComplianceApproval {
  id               String       @id @default(cuid())
  workflowId       String
  version          String
  approvedByUserId String
  approvedAt       DateTime     @default(now())
  approvalNotes    String?
  revokedAt        DateTime?
  organizationId   String
  workflow         Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approvedBy       User         @relation("ComplianceApprovedBy", fields: [approvedByUserId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, workflowId, approvedAt])
